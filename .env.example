# Google Gemini API key — used by the /api/z-chat route (server-side only).
# Get one from https://aistudio.google.com/apikey
# Copy this file to `.env.local` and fill in the value. `.env.local` is gitignored.
GEMINI_API_KEY=

# ── JARVIS access keys ───────────────────────────────────────────────
# Secret keys for the private /jarvis command center. Server-side only
# (no NEXT_PUBLIC_ prefix → never shipped to the browser). Validated by
# /api/jarvis/auth. Pick long, unguessable phrases — treat them like
# passwords. Example: a 5–6 word passphrase or a 24+ char random string.
JARVIS_KEY_AIMAAN=
JARVIS_KEY_ZAID=

# Anthropic (Claude) API key — used by /api/jarvis/chat (server-side
# only, never shipped to the browser). Get it from
# https://console.anthropic.com/settings/keys . Metered usage — see the
# rate-limit + token caps in the route. Restart `npm run dev` after
# setting this (env is read at server start).
ANTHROPIC_API_KEY=

# Deepgram (speech-to-text) — server-side; the route mints short-lived
# browser tokens from it. Use an Owner/Admin key. Free $200 credit.
DEEPGRAM_API_KEY=

# ElevenLabs (JARVIS's voice) — server-side only. Free tier 10k chars/mo.
# Optional: ELEVENLABS_VOICE_ID to override the default "Adam" voice.
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
